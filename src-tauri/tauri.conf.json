{
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "app",
      "dmg",
      "deb",
      "appimage"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "",
    "longDescription": "",
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5Q0RCMDMyRkYwQTQxOTIKUldTU1FRci9NckROT1FERSs0UjhTNzRsTHU0cjZGdTZzN1FTWGF4aldYdGFlTG56eWc5Uko4YzkK",
      "endpoints": [
        "https://raw.githubusercontent.com/open-goal/launcher/main/.tauri/latest-release-v2.json"
      ]
    },
    "opener": {
      "requireLiteralLeadingDot": false
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000/"
  },
  "productName": "OpenGOAL-Launcher",
  "mainBinaryName": "OpenGOAL-Launcher",
  "version": "2.10.2",
  "identifier": "OpenGOAL-Launcher",
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "$APPDATA/**"
        ]
      },
      "capabilities": [
        "desktop-capability"
      ]
    },
    "windows": [
      {
        "title": "OpenGOAL Launcher",
        "label": "main",
        "width": 1024,
        "height": 640,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "url": "/",
        "visible": true,
        "focus": true,
        "useHttpsScheme": true
      }
    ]
  }
}